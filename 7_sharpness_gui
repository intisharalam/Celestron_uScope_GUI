# Microscope viewer app
# This is my merged viewer (camera, zoom/pan, fps counter, the 3
# resolutions, snapshot) PLUS two new things: stacked capture, and
# adjustable sharpness.
#
# What is "stacked capture" (key: k)?
# ------------------------------------
# Single pictures from this camera are noisy/grainy, especially on flat
# areas. The noise is RANDOM each frame, but the actual specimen detail
# is the SAME every frame. So if I take like 16 pictures in a row and
# average them together, the random noise mostly cancels itself out
# (averaging N frames cuts noise by about sqrt(N)) but the real detail
# stays just as strong. So the averaged picture ends up looking cleaner,
# without making anything up - the detail was already there, just hidden
# under noise.
#
# IMPORTANT: the specimen and the microscope both need to stay
# COMPLETELY STILL for the 1-3 seconds it takes to grab all the frames,
# otherwise the average comes out blurry instead of sharp. Use the
# stand, don't do this handheld.
#
# What is "adjustable sharpness" ([ and ] keys)?
# ------------------------------------------------
# Before, sharpening was just one fixed amount that only got used on
# stacked pictures. Now there's a sharpness LEVEL from 0 to 5 that you
# can change anytime with [ and ], and it shows up live in the preview
# too, not just on saved pictures.
#
# But here's the catch: sharpening a single noisy frame just makes the
# noise look worse, it doesn't actually clean anything up. Sharpening
# only really helps on the STACKED (averaged) pictures because those are
# already clean. So if you press 'p' for a normal snapshot while
# sharpness is turned up, it'll still apply it (so the preview matches
# what gets saved) but it prints a warning, because that's not really
# what sharpening is good for. For an actually clean sharpened photo,
# use 'k' (stack) instead.
#
# Controls:
#   q = quit
#   + = zoom in
#   - = zoom out
#   0 = reset zoom/pan
#   w/a/s/d = pan when zoomed in
#   1 = low res (800x600, ~28fps)
#   2 = medium res (1280x960, ~24fps)
#   3 = high res (2048x1536, ~14fps)
#   p = take a normal single-frame snapshot
#   k = take a STACKED snapshot (averages several frames then sharpens)
#   [ = lower sharpness level
#   ] = raise sharpness level

import cv2
import numpy as np
import os
import time
from datetime import datetime

# where to save pictures
folder_path = os.path.dirname(os.path.abspath(__file__))
save_folder = os.path.join(folder_path, "img")
if not os.path.exists(save_folder):
    os.makedirs(save_folder)

# which camera to open
camera_index = 1

# zoom settings
zoom_min = 1.0
zoom_max = 8.0
zoom_step = 0.5
pan_step = 0.05

# window size on screen
window_width = 1000

# text drawing settings
font = cv2.FONT_HERSHEY_SIMPLEX
text_color = (0, 255, 0)
text_size = 0.55
text_thickness = 1

# --- stacking settings ---
# how many frames to average together for a stacked capture
stack_frame_count = 16

# --- sharpness settings ---
# sharpness is a level from 0 to 5 that you can change live with [ and ].
# each level needs an "amount" (how strong) and a "radius" (how wide the
# blur is that we use to find edges). I just picked numbers that ramp up
# gently - going too high on amount by itself starts making weird glowy
# outlines around edges, so radius goes up a little too as level goes up.
# level 0 = sharpening turned off completely (amount 0 does nothing).
sharpen_level_0 = (0.0, 2)
sharpen_level_1 = (0.7, 2)
sharpen_level_2 = (1.5, 2)
sharpen_level_3 = (2.2, 2)
sharpen_level_4 = (2.8, 3)
sharpen_level_5 = (3.5, 3)

sharpen_levels_list = [
    sharpen_level_0,
    sharpen_level_1,
    sharpen_level_2,
    sharpen_level_3,
    sharpen_level_4,
    sharpen_level_5,
]
max_sharpen_level = len(sharpen_levels_list) - 1  # = 5

# sharpness starts off (0) when the app launches, same as the old default
sharpen_level = 0


def resize_to_width(img, width):
    h, w = img.shape[:2]
    scale = width / w
    new_w = width
    new_h = int(h * scale)
    return cv2.resize(img, (new_w, new_h), interpolation=cv2.INTER_AREA)


def put_text_top_left(img, text):
    (text_w, text_h), _ = cv2.getTextSize(text, font, text_size, text_thickness)
    x = 10
    y = 10 + text_h
    cv2.rectangle(img, (x - 4, y - text_h - 4), (x + text_w + 4, y + 4), (0, 0, 0), -1)
    cv2.putText(img, text, (x, y), font, text_size, text_color, text_thickness, cv2.LINE_AA)


def put_text_bottom_left(img, text):
    h, w = img.shape[:2]
    (text_w, text_h), _ = cv2.getTextSize(text, font, text_size, text_thickness)
    x = 10
    y = h - 10
    cv2.rectangle(img, (x - 4, y - text_h - 4), (x + text_w + 4, y + 4), (0, 0, 0), -1)
    cv2.putText(img, text, (x, y), font, text_size, text_color, text_thickness, cv2.LINE_AA)


# copied from my zoom/pan test script, did not change this
def apply_zoom_pan(frame, zoom, pan_x, pan_y):
    if zoom <= 1.0:
        return frame

    h, w = frame.shape[:2]
    crop_w = w / zoom
    crop_h = h / zoom

    center_x = pan_x * w
    center_y = pan_y * h

    x0 = center_x - crop_w / 2
    y0 = center_y - crop_h / 2

    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x0 > w - crop_w:
        x0 = w - crop_w
    if y0 > h - crop_h:
        y0 = h - crop_h

    x0 = int(x0)
    y0 = int(y0)
    x1 = int(x0 + crop_w)
    y1 = int(y0 + crop_h)

    cropped = frame[y0:y1, x0:x1]
    return cv2.resize(cropped, (w, h))


# ----------------------------------------------------------------------
# Stacking + sharpening functions
# ----------------------------------------------------------------------

def capture_stack(cap, num_frames):
    # grabs num_frames pictures in a row and averages them together.
    # adding them up as float numbers instead of normal 0-255 numbers,
    # because normal numbers would overflow and wrap around before
    # reaching the real total
    total = None
    frames_added = 0

    for i in range(num_frames):
        success, frame = cap.read()
        if not success:
            continue  # just skip this one if it failed

        frame_as_float = frame.astype(np.float64)

        if total is None:
            total = frame_as_float
        else:
            total = total + frame_as_float

        frames_added = frames_added + 1

        show_capturing_message("Stacking frame " + str(i + 1) + "/" + str(num_frames) + "...")

    if frames_added == 0:
        return None

    average = total / frames_added
    average = np.clip(average, 0, 255)
    average = average.astype(np.uint8)
    return average


def unsharp_mask(image, amount, radius):
    # blur the image, subtract the blur from the original to find the
    # edges, then add those edges back in extra strong. this works well
    # on the stacked (already clean) image. doing this on a single noisy
    # frame just makes the grain stand out more instead of helping
    blurred = cv2.GaussianBlur(image, (0, 0), radius)
    sharpened = cv2.addWeighted(image, 1 + amount, blurred, -amount, 0)
    return sharpened


def sharpen_with_level(image, level):
    # looks up the amount/radius for the given level and runs unsharp_mask,
    # then clips and converts back to a normal image. made this its own
    # function since I now use it in 3 different places (preview, p, k)
    amount, radius = sharpen_levels_list[level]
    result = unsharp_mask(image.astype(np.float64), amount, radius)
    result = np.clip(result, 0, 255)
    result = result.astype(np.uint8)
    return result


def show_capturing_message(text):
    blank = np.zeros((480, window_width, 3), dtype="uint8")
    (text_w, text_h), _ = cv2.getTextSize(text, font, 1.0, 2)
    x = (window_width - text_w) // 2
    y = (480 + text_h) // 2
    cv2.putText(blank, text, (x, y), font, 1.0, text_color, 2, cv2.LINE_AA)
    cv2.putText(blank, "Keep the specimen and scope still!", (20, 460),
                font, 0.6, (0, 165, 255), 1, cv2.LINE_AA)
    cv2.imshow("Microscope Viewer", blank)
    cv2.waitKey(1)


def open_camera(width, height):
    new_cap = cv2.VideoCapture(camera_index)
    new_cap.set(cv2.CAP_PROP_FRAME_WIDTH, width)
    new_cap.set(cv2.CAP_PROP_FRAME_HEIGHT, height)
    return new_cap


def show_switching_screen(width, height):
    blank = np.zeros((480, window_width, 3), dtype="uint8")
    msg = "Switching to " + str(width) + "x" + str(height) + "..."
    (text_w, text_h), _ = cv2.getTextSize(msg, font, 1.0, 2)
    x = (window_width - text_w) // 2
    y = (480 + text_h) // 2
    cv2.putText(blank, msg, (x, y), font, 1.0, text_color, 2, cv2.LINE_AA)
    cv2.imshow("Microscope Viewer", blank)
    cv2.waitKey(1)


# start on resolution 3 (Max detail) since that's probably what you
# want for stacking anyway
res_choice = 3
res_width = 2048
res_height = 1536
res_name = "Max detail"

cap = open_camera(res_width, res_height)

if not cap.isOpened():
    print("Could not open the camera. Check the USB cable and make sure")
    print("no other program is using the camera already.")
    exit()

zoom = zoom_min
pan_x = 0.5
pan_y = 0.5

frame_count = 0
last_fps_time = time.time()
fps = 0.0

print("Controls: q=quit +/-=zoom 0=reset wasd=pan 1/2/3=res p=snapshot k=STACK [/]=sharpness")
print("Saving images to:", save_folder)
print("Stack capture uses", stack_frame_count, "frames averaged together.")
print("Sharpness starts at level", sharpen_level, "(0=off,", max_sharpen_level, "=max). Use [ and ] to adjust live.")

while True:
    success, frame = cap.read()
    if not success:
        continue

    frame_count = frame_count + 1
    now = time.time()
    if now - last_fps_time >= 1.0:
        fps = frame_count / (now - last_fps_time)
        frame_count = 0
        last_fps_time = now

    view = apply_zoom_pan(frame, zoom, pan_x, pan_y)

    if sharpen_level > 0:
        view = sharpen_with_level(view, sharpen_level)

    displayed = resize_to_width(view, window_width)

    status_text = "%.1f fps   %dx%d (%s)   zoom %.1fx   sharpen %d/%d" % (fps, res_width, res_height, res_name, zoom, sharpen_level, max_sharpen_level)
    put_text_top_left(displayed, status_text)
    put_text_bottom_left(displayed, "q quit | +/- zoom | 0 reset | wasd pan | 1/2/3 res | p snapshot | k STACK | [ ] sharpen")

    cv2.imshow("Microscope Viewer", displayed)

    key = cv2.waitKey(1) & 0xFF

    if key == ord('q'):
        break

    elif key == ord('['):
        sharpen_level = sharpen_level - 1
        if sharpen_level < 0:
            sharpen_level = 0

    elif key == ord(']'):
        sharpen_level = sharpen_level + 1
        if sharpen_level > max_sharpen_level:
            sharpen_level = max_sharpen_level

    elif key == ord('+') or key == ord('='):
        zoom = zoom + zoom_step
        if zoom > zoom_max:
            zoom = zoom_max

    elif key == ord('-'):
        zoom = zoom - zoom_step
        if zoom < zoom_min:
            zoom = zoom_min

    elif key == ord('0'):
        zoom = zoom_min
        pan_x = 0.5
        pan_y = 0.5

    elif key == ord('w'):
        pan_y = pan_y - pan_step
        if pan_y < 0.0:
            pan_y = 0.0

    elif key == ord('s'):
        pan_y = pan_y + pan_step
        if pan_y > 1.0:
            pan_y = 1.0

    elif key == ord('a'):
        pan_x = pan_x - pan_step
        if pan_x < 0.0:
            pan_x = 0.0

    elif key == ord('d'):
        pan_x = pan_x + pan_step
        if pan_x > 1.0:
            pan_x = 1.0

    elif key == ord('1') and res_choice != 1:
        res_choice = 1
        res_width = 800
        res_height = 600
        res_name = "Fast"
        show_switching_screen(res_width, res_height)
        cap.release()
        cap = open_camera(res_width, res_height)
        frame_count = 0
        last_fps_time = time.time()

    elif key == ord('2') and res_choice != 2:
        res_choice = 2
        res_width = 1280
        res_height = 960
        res_name = "Balanced"
        show_switching_screen(res_width, res_height)
        cap.release()
        cap = open_camera(res_width, res_height)
        frame_count = 0
        last_fps_time = time.time()

    elif key == ord('3') and res_choice != 3:
        res_choice = 3
        res_width = 2048
        res_height = 1536
        res_name = "Max detail"
        show_switching_screen(res_width, res_height)
        cap.release()
        cap = open_camera(res_width, res_height)
        frame_count = 0
        last_fps_time = time.time()

    elif key == ord('p'):
        # normal single-frame snapshot. if sharpness is turned on, I
        # apply it here too so the saved file matches the preview, but
        # this isn't really what sharpening is good for since the raw
        # frame is still noisy - sharpening a noisy frame just makes the
        # noise worse, not better. so print a warning about it.
        to_save = frame
        if sharpen_level > 0:
            to_save = sharpen_with_level(frame, sharpen_level)

        now_str = datetime.now().strftime("%Y%m%d_%H%M%S")
        filename = "snapshot_" + now_str + ".png"
        full_path = os.path.join(save_folder, filename)
        cv2.imwrite(full_path, to_save)
        print("Saved single-frame snapshot (" + str(res_width) + "x" + str(res_height) + "):", full_path)
        if sharpen_level > 0:
            print("  NOTE: sharpen level", sharpen_level, "was applied to a single RAW frame -")
            print("  this just amplifies the noise, it does not clean anything up.")
            print("  For an actually clean sharpened picture, use 'k' (stack) instead.")

    elif key == ord('k'):
        # stacked capture - average several frames together, then sharpen
        # at the current level. this is the right place to sharpen since
        # averaging already cleaned the noise out
        averaged = capture_stack(cap, stack_frame_count)

        if averaged is None:
            print("Stack capture failed - could not read any frames.")
        else:
            sharpened = sharpen_with_level(averaged, sharpen_level)

            now_str = datetime.now().strftime("%Y%m%d_%H%M%S")
            raw_filename = "stacked_" + now_str + "_raw.png"
            sharp_filename = "stacked_" + now_str + "_sharpened.png"
            raw_path = os.path.join(save_folder, raw_filename)
            sharp_path = os.path.join(save_folder, sharp_filename)

            # save both the plain averaged one and the sharpened one,
            # in case I want to compare them or the level needs changing
            cv2.imwrite(raw_path, averaged)
            cv2.imwrite(sharp_path, sharpened)

            print("Saved stacked capture (" + str(stack_frame_count) + " frames, " + str(res_width) + "x" + str(res_height) + ", sharpen level " + str(sharpen_level) + "):")
            print("  denoised (no sharpen):", raw_path)
            print("  denoised + sharpened :", sharp_path)

cap.release()
cv2.destroyAllWindows()